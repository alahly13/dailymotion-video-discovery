# .env.example contains placeholders only and is NOT a real secret file.
# Never commit real secrets in .env files.
# Use Vercel Environment Variables, GitHub Codespaces secrets, and GitHub Actions secrets.

# ===== Public/browser-safe variables =====
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# ===== Server-only required variables =====
# DATABASE_URL (required, server-only): Prisma runtime connection.
# Online/Vercel-first recommendation: use Supabase Session Pooler for IPv4 compatibility.
# Example (placeholder only):
# postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres"

# DIRECT_URL (required, server-only): Prisma migration/direct operations connection.
# Use Supabase direct connection only when your environment supports IPv6.
# In IPv4-only online environments (Vercel/Codespaces/GitHub Actions), DIRECT_URL may safely equal DATABASE_URL (Session Pooler).
# Direct host warning: db.<project-ref>.supabase.co may fail without IPv6 support or Supabase IPv4 add-on.
# Example Session Pooler value (placeholder only):
# postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Required server-only AI key.
GEMINI_API_KEY="your-server-only-gemini-key"

# ===== Server-only optional variables =====
SUPABASE_SERVICE_ROLE_KEY=""
DAILYMOTION_API_BASE_URL="https://api.dailymotion.com"
DAILYMOTION_API_KEY=""
CRON_SECRET=""
WEBHOOK_SECRET=""

# ===== Feature flags =====
ENABLE_PGVECTOR="false"
ENABLE_MANIFEST_PERSISTENCE="true"

# ===== Fetch safety limits =====
MAX_CHANNEL_FETCH_PAGES="200"
MAX_CHANNEL_FETCH_ITEMS="10000"
CHANNEL_FETCH_DELAY_MS="250"

# ===== Future AI/semantic search variables =====
AI_EMBEDDING_MODEL=""
