# .env.example contains placeholders only and is NOT a real secret file.
# Never commit real secrets in .env files.
# Use GitHub Codespaces secrets, GitHub Actions secrets, and Vercel environment variables.

# Supabase connection strings are available in Supabase Dashboard -> Connect.
# DATABASE_URL is used for normal application/server database access.
# DIRECT_URL is used for migrations and direct Prisma operations.

# ===== Public/browser-safe variables =====
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# ===== Server-only required variables =====
DATABASE_URL="postgresql://user:password@host:6543/postgres?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/postgres?sslmode=require"
GEMINI_API_KEY="your-server-only-gemini-key"

# ===== Server-only optional variables =====
SUPABASE_SERVICE_ROLE_KEY=""
DAILYMOTION_API_BASE_URL="https://api.dailymotion.com"
DAILYMOTION_API_KEY=""
CRON_SECRET=""
WEBHOOK_SECRET=""

# ===== Feature flags =====
ENABLE_PGVECTOR="false"
ENABLE_MANIFEST_PERSISTENCE="true"

# ===== Fetch safety limits =====
MAX_CHANNEL_FETCH_PAGES="200"
MAX_CHANNEL_FETCH_ITEMS="10000"
CHANNEL_FETCH_DELAY_MS="250"

# ===== Future AI/semantic search variables =====
AI_EMBEDDING_MODEL=""
