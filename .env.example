# Placeholder documentation only. Do not put real secrets in this file.
# Create a root .env.local for local/online terminals, or configure these keys
# in Vercel, GitHub Codespaces, and GitHub Actions secrets.

# ===== Public/browser-safe variables =====
# Required. These are safe to expose because NEXT_PUBLIC_* values are bundled for the browser.
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# ===== Server-only required variables =====
# Required DB link. Use Supabase Session Pooler on the free plan and in IPv4-limited
# environments such as Vercel, GitHub Codespaces, GitHub Actions, and many Windows shells.
# Placeholder shape:
# postgresql://postgres.<project-ref>:<percent-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Percent-encode reserved password characters such as #, @, ?, /, and $ before pasting.
# For the Session Pooler on port 5432, Prisma does not require a pgbouncer query
# parameter. Only add Prisma connection query parameters when official
# Supabase/Prisma troubleshooting for your exact pooler mode calls for them.
# Do not use DIRECT_URL in this project. Use Supabase Session Pooler for DATABASE_URL.
DATABASE_URL="postgresql://postgres.<project-ref>:<percent-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Required for AI routes. Server-only. Never prefix with NEXT_PUBLIC_.
GEMINI_API_KEY="your-server-only-gemini-key"

# ===== Server-only optional variables =====
# Service role key is optional and should only be used for privileged server flows.
SUPABASE_SERVICE_ROLE_KEY=""

# Dailymotion public metadata discovery works without an API key where endpoints allow it.
DAILYMOTION_API_BASE_URL="https://api.dailymotion.com"
DAILYMOTION_API_KEY=""

CRON_SECRET=""
WEBHOOK_SECRET=""

# ===== Feature flags =====
ENABLE_PGVECTOR="false"
ENABLE_MANIFEST_PERSISTENCE="true"

# ===== Fetch safety limits =====
MAX_CHANNEL_FETCH_PAGES="200"
MAX_CHANNEL_FETCH_ITEMS="10000"
CHANNEL_FETCH_DELAY_MS="250"

# ===== Future-only AI/semantic search variables =====
AI_EMBEDDING_MODEL=""
