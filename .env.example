# Public/browser-safe variables (can be exposed to the browser)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# Server-only required variables (must never use NEXT_PUBLIC_)
# DATABASE_URL/DIRECT_URL are used for Supabase PostgreSQL migrations and server DB access.
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
# Gemini key is server-only. Never expose in client code.
GEMINI_API_KEY="replace-with-server-only-gemini-key"

# Server-only optional/future variables
# SUPABASE_SERVICE_ROLE_KEY is highly sensitive and must never be used in client code.
SUPABASE_SERVICE_ROLE_KEY=""
DAILYMOTION_API_BASE_URL="https://api.dailymotion.com"
DAILYMOTION_API_KEY=""
CRON_SECRET=""
WEBHOOK_SECRET=""
AI_EMBEDDING_MODEL=""
ENABLE_PGVECTOR="false"
ENABLE_MANIFEST_PERSISTENCE="true"
MAX_CHANNEL_FETCH_PAGES="200"
MAX_CHANNEL_FETCH_ITEMS="10000"
CHANNEL_FETCH_DELAY_MS="250"
