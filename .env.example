# .env.example contains placeholders only.
# Put real values in Vercel -> Project Settings -> Environment Variables.
# NEXT_PUBLIC_* values are browser-visible. Server-only secrets must NEVER start with NEXT_PUBLIC_.
# Optional/future variables must not block startup.
# DAILYMOTION_API_KEY is optional: public metadata should work without it where Dailymotion allows public access.
# GEMINI_API_KEY and SUPABASE_SERVICE_ROLE_KEY are sensitive server-only values.

# ===== Public/browser-safe variables =====
# Category: public_browser_safe | Required: required_now | Browser exposure: allowed
# Purpose: public app origin for links/redirects.
# Get it from: Vercel domain settings.
# Accepted: https://your-project.vercel.app or custom domain.
# Missing behavior: incorrect links/redirect handling.
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# Category: public_browser_safe | Required: required_now | Browser exposure: allowed
# Purpose: Supabase project URL used by browser/server SSR clients.
# Get it from: Supabase project settings.
# Missing behavior: Supabase clients cannot initialize.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Category: public_browser_safe | Required: required_now | Browser exposure: allowed
# Purpose: Supabase publishable (anon) key.
# Get it from: Supabase API settings.
# Missing behavior: public auth/data client setup fails fast.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# ===== Server-only required variables =====
DATABASE_URL="your-supabase-pooled-postgres-url"
DIRECT_URL="your-supabase-direct-postgres-url"
GEMINI_API_KEY="your-server-only-gemini-key"

# ===== Server-only optional variables =====
SUPABASE_SERVICE_ROLE_KEY=""
DAILYMOTION_API_BASE_URL="https://api.dailymotion.com"
DAILYMOTION_API_KEY=""
CRON_SECRET=""
WEBHOOK_SECRET=""

# ===== Feature flags =====
ENABLE_PGVECTOR="false"
ENABLE_MANIFEST_PERSISTENCE="true"

# ===== Fetch safety limits =====
MAX_CHANNEL_FETCH_PAGES="200"
MAX_CHANNEL_FETCH_ITEMS="10000"
CHANNEL_FETCH_DELAY_MS="250"

# ===== Future AI/semantic search variables =====
AI_EMBEDDING_MODEL=""
